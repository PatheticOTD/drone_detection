<diagram id="lg" name="Легенда"><mxGraphModel dx="900" dy="700" grid="1" gridSize="10" page="1" pageWidth="850" pageHeight="1100"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="Lt" value="Условные обозначения" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="290" y="16" width="330" height="32" as="geometry"/></mxCell><mxCell id="Ls" value="Подписи на стрелках — размер тензора&#10;C×H×W (2D) или C×L (1D)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="290" y="300" width="330" height="50" as="geometry"/></mxCell><mxCell id="L0" value="Вход / данные" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="60" width="320" height="40" as="geometry"/></mxCell><mxCell id="L1" value="Свёрточный слой (Conv+BN+ReLU)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="108" width="320" height="40" as="geometry"/></mxCell><mxCell id="L2" value="Подвыборка / пулинг" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="156" width="320" height="40" as="geometry"/></mxCell><mxCell id="L3" value="Полносвязный слой (FC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="204" width="320" height="40" as="geometry"/></mxCell><mxCell id="L4" value="Остаточный блок (residual, ⊕)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="252" width="320" height="40" as="geometry"/></mxCell><mxCell id="L5" value="Рекуррентный слой (BiLSTM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="300" width="320" height="40" as="geometry"/></mxCell><mxCell id="L6" value="Преобразование (flatten/reshape)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="348" width="320" height="40" as="geometry"/></mxCell><mxCell id="L7" value="Backbone / Neck / Head" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="396" width="320" height="40" as="geometry"/></mxCell><mxCell id="L8" value="Трансформер (encoder/decoder)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="444" width="320" height="40" as="geometry"/></mxCell><mxCell id="L9" value="Выход (классы / рамки)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="492" width="320" height="40" as="geometry"/></mxCell></root></mxGraphModel></diagram>
<diagram id="yl" name="YOLO (v5n/v8n/v8s/v11n)"><mxGraphModel dx="900" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="ylT" value="Семейство YOLO — одностадийный анкер-фри детектор" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="270" y="18" width="320" height="34" as="geometry"/></mxCell><mxCell id="yln0" value="Вход: изображение 640×640×3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="64" width="260" height="46" as="geometry"/></mxCell><mxCell id="yln1" value="Backbone (CSP / CSPDarknet / C3k2)&#10;→ P3 256×80×80, P4 512×40×40, P5 512×20×20" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="154" width="260" height="46" as="geometry"/></mxCell><mxCell id="yln2" value="Neck (PAN / PANet): объединение масштабов&#10;→ уточнённые P3 80×80, P4 40×40, P5 20×20" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="244" width="260" height="46" as="geometry"/></mxCell><mxCell id="yln3" value="Детекционная голова (3 масштаба), anchor-free&#10;→ на 80×80, 40×40, 20×20: классы + рамки" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="334" width="260" height="46" as="geometry"/></mxCell><mxCell id="yln4" value="Выход: рамки + классы (после NMS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="424" width="260" height="46" as="geometry"/></mxCell><mxCell id="yle0" value="640×640×3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#555555;fontSize=11;fontColor=#1a1a1a;fontStyle=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="yln0" target="yln1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="yle1" value="P3/P4/P5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#555555;fontSize=11;fontColor=#1a1a1a;fontStyle=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="yln1" target="yln2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="yle2" value="80/40/20" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#555555;fontSize=11;fontColor=#1a1a1a;fontStyle=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="yln2" target="yln3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="yle3" value="8400×(4+nc)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#555555;fontSize=11;fontColor=#1a1a1a;fontStyle=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="yln3" target="yln4"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ylN" value="Общая схема семейства YOLO.&#10;Вход 640×640×3.&#10;&#10;Различия вариантов:&#10;• YOLOv5n — CSPDarknet (~2,5 млн)&#10;• YOLOv8n — CSP-backbone (~3,2 млн)&#10;• YOLOv8s — шире слои (~11 млн)&#10;• YOLOv11n — backbone C3k2 (~2,6 млн)&#10;&#10;P3/P4/P5 — карты признаков с шагом 8/16/32." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="610" y="70" width="250" height="170" as="geometry"/></mxCell></root></mxGraphModel></diagram>
<diagram id="rt" name="RT-DETR-L"><mxGraphModel dx="900" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="rtT" value="RT-DETR-L — трансформерный детектор (~33 млн)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="270" y="18" width="320" height="34" as="geometry"/></mxCell><mxCell id="rtn0" value="Вход: 640×640×3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="64" width="260" height="46" as="geometry"/></mxCell><mxCell id="rtn1" value="Backbone (CNN): карты признаков&#10;→ S3 80×80, S4 40×40, S5 20×20" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="154" width="260" height="46" as="geometry"/></mxCell><mxCell id="rtn2" value="Гибридный энкодер (AIFI + CCFF)&#10;внутри- и кросс-масштабное внимание" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="244" width="260" height="46" as="geometry"/></mxCell><mxCell id="rtn3" value="Декодер-трансформер: 300 объектных запросов" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="334" width="260" height="46" as="geometry"/></mxCell><mxCell id="rtn4" value="Выход: 300 предсказаний — рамки + классы (без NMS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=center;verticalAlign=middle;arcSize=10;" vertex="1" parent="1"><mxGeometry x="300" y="424" width="260" height="46" as="geometry"/></mxCell><mxCell id="rte0" value="640×640×3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#555555;fontSize=11;fontColor=#1a1a1a;fontStyle=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="rtn0" target="rtn1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="rte1" value="S3/S4/S5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#555555;fontSize=11;fontColor=#1a1a1a;fontStyle=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="rtn1" target="rtn2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="rte2" value="токены" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#555555;fontSize=11;fontColor=#1a1a1a;fontStyle=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="rtn2" target="rtn3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="rte3" value="300×d" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#555555;fontSize=11;fontColor=#1a1a1a;fontStyle=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="rtn3" target="rtn4"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel></diagram>
